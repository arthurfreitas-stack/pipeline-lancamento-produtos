# Supabase — obtenha em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Prisma — Supabase: Project Settings > Database > Connection string (Transaction mode porta 6543)
DATABASE_URL="postgresql://postgres.SEU_PROJECT_ID:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma — Supabase: Connection string (Session mode porta 5432) para migrations
DIRECT_URL="postgresql://postgres.SEU_PROJECT_ID:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
